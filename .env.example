# ============================================================
# Car Model Skill — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Z.ai API key — NOW STORED AS A DOCKER SECRET (not here)
# Put your key in: secrets/zai_api_key.txt
# Then run: chmod 0400 secrets/zai_api_key.txt
# Get a key from: https://z.ai/subscribe (Coding Plan)
# ZAI_API_KEY is no longer read from this file.

# Z.ai primary model — GLM-5 with fallback chain
# Note: requires OpenClaw latest build. After setup verify with:
#   docker compose run --rm --profile cli openclaw-cli models list --all --provider zai
ZAI_PRIMARY_MODEL=zai/glm-5
ZAI_FALLBACK_MODELS=zai/glm-4.7,zai/glm-4.6,zai/glm-4.5-air

# OpenClaw gateway port (loopback only — do not change to 0.0.0.0)
OPENCLAW_GATEWAY_PORT=18789

# Workspace directory on host (relative to project root)
OPENCLAW_WORKSPACE_DIR=./workspace

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Review mode: auto (colour variants skip review) | manual (all go to review)
REVIEW_MODE=auto

# Maximum concurrent jobs (keep low — Blender is memory-hungry)
MAX_CONCURRENT_JOBS=1

# Frontend port (bound to 0.0.0.0 — accessible from LAN)
FRONTEND_PORT=3000
